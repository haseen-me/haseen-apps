# Copy to .env.production before running docker compose -f docker-compose.prod.yml

POSTGRES_DB=haseen
POSTGRES_USER=haseen
POSTGRES_PASSWORD=replace-with-a-strong-password

SESSION_SECRET=replace-with-a-long-random-secret

SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=

# Comma-separated list used by the gateway CORS middleware.
CORS_ALLOWED_ORIGINS=https://haseen.me,https://mail.haseen.me,https://accounts.haseen.me,https://drive.haseen.me,https://calendar.haseen.me,https://contacts.haseen.me
