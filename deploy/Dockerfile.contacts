FROM golang:1.23-alpine AS builder
WORKDIR /build
COPY services/contacts/go.mod services/contacts/go.sum ./
RUN go mod download
COPY services/contacts/ ./
ENV GOWORK=off
RUN CGO_ENABLED=0 go build -ldflags='-s -w' -o /contacts .

FROM alpine:3.20
RUN apk --no-cache add ca-certificates
COPY --from=builder /contacts /contacts
EXPOSE 4008
CMD ["/contacts"]
