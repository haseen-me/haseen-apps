FROM golang:1.24.1-alpine AS builder
WORKDIR /build
COPY services/drive/go.mod services/drive/go.sum ./
RUN go mod download
COPY services/drive/ ./
ENV GOWORK=off
RUN CGO_ENABLED=0 go build -ldflags='-s -w' -o /drive .

FROM alpine:3.20
RUN apk --no-cache add ca-certificates
COPY --from=builder /drive /drive
EXPOSE 8083
CMD ["/drive"]
