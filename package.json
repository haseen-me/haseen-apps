{
  "name": "haseen-apps",
  "private": true,
  "version": "0.0.0",
  "description": "Haseen — Privacy-first, end-to-end encrypted productivity suite",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo dev",
    "dev:web": "turbo dev --filter=@haseen-me/web",
    "dev:mail": "turbo dev --filter=@haseen-me/mail-app",
    "dev:drive": "turbo dev --filter=@haseen-me/drive-app",
    "dev:accounts": "turbo dev --filter=@haseen-me/accounts",
    "dev:console": "turbo dev --filter=@haseen-me/console-app",
    "dev:ui-docs": "turbo dev --filter=@haseen-me/ui-docs",
    "dev:calendar": "turbo dev --filter=@haseen-me/calendar-app",
    "dev:contacts": "turbo dev --filter=@haseen-me/contacts-app",
    "build": "turbo build",
    "build:apps": "turbo build --filter='./apps/*'",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "proto:gen": "buf generate",
    "proto:lint": "buf lint",
    "test": "turbo test",
    "clean": "turbo clean && rm -rf node_modules"
  },
  "devDependencies": {
    "@bufbuild/protobuf": "^2.11.0",
    "@bufbuild/protoc-gen-es": "^2.11.0",
    "prettier": "^3.5.0",
    "turbo": "^2.4.0"
  },
  "prettier": {
    "singleQuote": true,
    "trailingComma": "es5",
    "printWidth": 100,
    "tabWidth": 2,
    "semi": true
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "npm@10.9.4"
}
