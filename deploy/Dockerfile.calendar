FROM golang:1.24.1-alpine AS builder
WORKDIR /build
COPY services/calendar/go.mod services/calendar/go.sum ./
RUN go mod download
COPY services/calendar/ ./
ENV GOWORK=off
RUN CGO_ENABLED=0 go build -ldflags='-s -w' -o /calendar .

FROM alpine:3.20
RUN apk --no-cache add ca-certificates
COPY --from=builder /calendar /calendar
EXPOSE 8085
CMD ["/calendar"]
