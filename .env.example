# Haseen Apps — Environment Variables
# Copy this to .env and fill in real values

# PostgreSQL
DATABASE_URL=postgres://haseen:haseen_dev_password@localhost:5432/haseen?sslmode=disable

# Redis
REDIS_URL=redis://localhost:6379/0

# Service Ports
GATEWAY_PORT=8080
AUTH_PORT=8081
MAIL_PORT=8082
DRIVE_PORT=8083
KEYSERVER_PORT=8084

# JWT / Session
SESSION_SECRET=change-me-in-production

# SMTP (for outbound email)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=

# Blob Storage (drive)
BLOB_STORAGE_PATH=./data/blobs
