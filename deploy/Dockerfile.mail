FROM golang:1.23-alpine AS builder
WORKDIR /build
COPY services/mail/go.mod services/mail/go.sum ./
RUN go mod download
COPY services/mail/ ./
ENV GOWORK=off
RUN CGO_ENABLED=0 go build -ldflags='-s -w' -o /mail .

FROM alpine:3.20
RUN apk --no-cache add ca-certificates
COPY --from=builder /mail /mail
EXPOSE 8082
CMD ["/mail"]
