FROM golang:1.23-alpine AS builder
WORKDIR /build
COPY services/keyserver/go.mod services/keyserver/go.sum ./
RUN go mod download
COPY services/keyserver/ ./
ENV GOWORK=off
RUN CGO_ENABLED=0 go build -ldflags='-s -w' -o /keyserver .

FROM alpine:3.20
RUN apk --no-cache add ca-certificates
COPY --from=builder /keyserver /keyserver
EXPOSE 8084
CMD ["/keyserver"]
