{
  "name": "@haseen-me/shared",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./ErrorBoundary": {
      "types": "./dist/ErrorBoundary.d.ts",
      "import": "./dist/ErrorBoundary.js"
    },
    "./toast": {
      "types": "./dist/toast.d.ts",
      "import": "./dist/toast.js"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts src/ErrorBoundary.tsx src/toast.ts --format esm --dts",
    "dev": "tsup src/index.ts src/ErrorBoundary.tsx src/toast.ts --format esm --dts --watch",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "peerDependencies": {
    "react": ">=18",
    "zustand": ">=4"
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "tsup": "^8.4.0",
    "typescript": "^5.8.0"
  }
}
